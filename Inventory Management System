import java.util.*;

class Product {
    int id;
    String name;
    int stock;

    Product(int id, String name, int stock) {
        this.id = id;
        this.name = name;
        this.stock = stock;
    }
}

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Product> list = new ArrayList<>();
        int ch;

        do {
            System.out.println("1.Add Product 2.View Products 3.Update Stock 4.Exit");
            ch = sc.nextInt();

            switch (ch) {
                case 1:
                    System.out.print("Enter id name stock: ");
                    int id = sc.nextInt();
                    String name = sc.next();
                    int stock = sc.nextInt();
                    list.add(new Product(id, name, stock));
                    break;

                case 2:
                    for (Product p : list) {
                        System.out.println(p.id + " " + p.name + " " + p.stock);
                    }
                    break;

                case 3:
                    System.out.print("Enter product id: ");
                    int pid = sc.nextInt();
                    boolean found = false;
                    for (Product p : list) {
                        if (p.id == pid) {
                            System.out.print("Enter new stock: ");
                            p.stock = sc.nextInt();
                            System.out.println("Stock updated");
                            found = true;
                        }
                    }
                    if (!found) System.out.println("Product not found");
                    break;

                case 4:
                    System.out.println("Exit");
                    break;

                default:
                    System.out.println("Invalid");
            }
        } while (ch != 4);
    }
}
